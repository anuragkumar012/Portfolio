# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage
.nyc_output

# Next.js build and output
/.next/
/out/

# Production builds
/build
/dist

# Debugging logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log

# Environment variables & local configuration
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
.env*.local.tmp
# Avoid committing any real secrets, but allow .env.example
!.env.example

# Vercel deployments
.vercel

# TypeScript build info
*.tsbuildinfo
next-env.d.ts

# IDE / Editors
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS metadata files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Misc certificates / secrets
*.pem
*.key
